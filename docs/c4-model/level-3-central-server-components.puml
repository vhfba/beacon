@startuml
title BEACON - Component Diagram (C3) · Central Server

!includeurl https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

Person(admin, "Admin")
Person_Ext(probe, "Probe Agent")

System_Boundary(central, "Central Server") {

  Container_Boundary(gqlapi, "GraphQL API") {
    Component(qresolver, "Query Resolver", "GraphQL Resolver", "Probe status and metrics summary queries")
    Component(mresolver, "Mutation Resolver", "GraphQL Resolver", "Enable/disable tests and set schedule interval")
    Component(auth, "Auth Middleware", "Middleware", "API key/token validation")
    Component(schema, "Schema", "GraphQL SDL", "Type definitions and request validation")
  }

  Container_Boundary(cfgmgr, "Config Manager") {
    Component(registry, "Probe Registry", "Service", "Tracks registered probes and last-seen heartbeat")
    Component(testcfg, "Test Config Service", "Service", "Stores enabled plugins and scheduling interval")
  }

  Container_Boundary(pluginrepo, "Plugin Repository") {
    Component(pluginstore, "Plugin Store", "Service", "Serves plugin bundles")
    Component(manifest, "Plugin Manifest", "Service", "Resolves plugin name/version/checksum metadata")
  }

  ComponentDb(db, "Config Store", "SQLite/PostgreSQL", "Configuration and plugin metadata persistence")
}

Rel(auth, qresolver, "Pass if valid")
Rel(auth, mresolver, "Pass if valid")
Rel(schema, qresolver, "Validate queries")
Rel(schema, mresolver, "Validate mutations")

Rel(qresolver, registry, "Query probe list and last-seen state")
Rel(qresolver, testcfg, "Query enabled tests")
Rel(mresolver, testcfg, "Update test configuration")
Rel(mresolver, registry, "Register/deregister probe")
Rel(testcfg, db, "Read/write")
Rel(registry, db, "Read/write")
Rel(pluginstore, db, "Read plugin bundle metadata")
Rel(manifest, db, "Read manifest rows")
Rel(manifest, pluginstore, "Resolve bundle reference")

Rel(admin, auth, "GraphQL mutations and queries", "HTTP")
Rel(probe, auth, "Fetch config and register", "HTTP")
Rel(probe, manifest, "Check latest plugin metadata")
Rel(probe, pluginstore, "Download plugin bundle")

note right of auth
  planned
end note

@enduml