@startuml
title BEACON - Container Diagram (C2)

!includeurl https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

Person(admin, "Admin")

System_Boundary(central, "Central Server") {
  Container(gql, "GraphQL API", "Python/Node.js, HTTP", "Serves central configuration and probe status")
  ContainerDb(cfg, "Config Store", "SQLite/PostgreSQL", "Stores probe registry and test configuration")
}

System_Boundary(monitoring, "Monitoring Stack") {
  ContainerDb(prom, "Prometheus", "Prometheus", "Scrapes probe metrics and stores time-series")
  Container(graf, "Grafana", "Grafana", "Dashboards and metric exploration")
}

System_Boundary(probes, "Raspberry Pi Probe xN") {
  Container(agent, "Probe Agent", "Python/C on Raspberry Pi OS", "Polls config and runs test plugins")
  Container(metrics, "/metrics endpoint", "HTTP", "Exposes latest probe metrics to Prometheus")
}

Rel(gql, cfg, "Read/write configuration")
Rel(graf, prom, "Execute PromQL queries", "HTTP")
Rel(agent, metrics, "Update metrics on each test run")

Rel(admin, gql, "Configure probes and view status", "GraphQL over HTTP")
Rel(admin, graf, "View dashboards")

Rel(agent, gql, "Poll configuration", "GraphQL over HTTP")
Rel(gql, agent, "Return enabled tests and interval", "GraphQL response")
Rel(prom, metrics, "Scrape /metrics every 15s", "HTTP GET")

note bottom of agent
  Each Pi runs one Agent process.
  Scheduler triggers plugins;
  results written to /metrics.
end note

note bottom of prom
  Prometheus scrapes all probes.
end note

@enduml