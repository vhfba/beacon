{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "GraphQL": {
    "EnableIntrospection": false,
    "MaxQueryDepth": 15,
    "MaxQueryComplexity": 1000
  },
  "Plugins": {
    "BundleDirectory": "plugin-bundles"
  },
  "Monitoring": {
    "Prometheus": {
      "ServiceDiscoveryToken": "",
      "DefaultProbeMetricsPort": 9464,
      "DefaultMetricsPath": "/metrics"
    },
    "Grafana": {
      "EmbedBaseUrl": "http://localhost:3001",
      "ApiBaseUrl": "http://localhost:3001",
      "DashboardBaseUid": "beacon-probe-health",
      "ApiToken": ""
    }
  },
  "Auth": {
    "AdminApiKey": "",
    "ProbeApiKey": ""
  }
}
